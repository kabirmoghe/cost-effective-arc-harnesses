# Copy to `.env` (which is gitignored) and fill in real values.
#   cp .env.example .env

# --- LLM providers ---------------------------------------------------------
# OpenRouter is the primary provider. The headline runs use DeepSeek V3.2 pinned
# to the AtlasCloud FP8 backend; Qwen3 / Kimi / Llama panel models also route
# through OpenRouter. Required for baseline, CoT, arc_base, pipeline, orchestrator.
OPENROUTER_API_KEY=sk-or-...

# Optional. Only needed for `--provider openai` (e.g. an external flagship
# reference point). Leave unset otherwise.
OPENAI_API_KEY=sk-...

# Optional / legacy. The first-party DeepSeek `deepseek-chat` alias moved to V4
# in May 2026, so the `deepseek` provider is no longer used for V3.2. Kept only
# if you explicitly target the first-party API.
DEEPSEEK_API_KEY=

# --- Database --------------------------------------------------------------
# Postgres tracking DB (canonical source of truth). Matches database/compose.yaml
# (local compose maps the container's 5432 to host port 5433). This is also the
# default baked into database/client.py and migrate.py if the var is unset.
DATABASE_URL=postgresql://kabirmoghe:postgres@localhost:5433/arc_evaluation

# --- Tracing (optional) ----------------------------------------------------
# LangSmith request tracing. Entirely optional; unset to disable.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=arc-agi
